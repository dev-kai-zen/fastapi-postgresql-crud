# Copy to `.env` and adjust. `.env` is gitignored.
#
# Docker Compose reads this file automatically when it sits next to
# `docker-compose.yaml` and substitutes ${VAR} in the compose file.

# --- PostgreSQL (container + published port) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=fastapi_crud
# Host port (left side of "host:5432"). Change if 5435 is taken.
POSTGRES_PUBLISH_PORT=5435

# --- FastAPI / SQLAlchemy (use same user, password, db, and HOST port) ---
# If the password has special characters, URL-encode them in DATABASE_URL.
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5435/fastapi_crud

# --- Redis (Docker maps host port -> container 6379) ---
REDIS_PUBLISH_PORT=6380
REDIS_URL=redis://localhost:6380/0
REDIS_PASSWORD=sample_password
REDIS_URL_WITH_PASSWORD=redis://sample_password@localhost:6380/0
